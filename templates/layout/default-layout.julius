      theme: 'snow',
      modules: {
        toolbar: {
          container: '#board-post-description-toolbar',
          handlers: {
            image: async () => {
              if (!uploadUrl) return;

              const fileInput = document.createElement('input');
              fileInput.type = 'file';
              fileInput.accept = 'image/*';
              fileInput.addEventListener('change', async () => {
                const file = fileInput.files?.[0];
                if (!file) return;

                const body = new FormData();
                body.append('file', file);
                if (csrfParam && csrfToken) {
                  body.append(csrfParam, csrfToken);
                }

                try {
                  const response = await fetch(uploadUrl, {
                    method: 'POST',
                    body,
                    headers: {
                      Accept: 'application/json',
                      'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'same-origin'
                  });
                  if (response.redirected && response.url.includes('/auth/')) {
                    throw new Error('로그인이 필요합니다.');
                  }

                  const contentType = response.headers.get('content-type') || '';
                  const payload = contentType.includes('application/json')
                    ? await response.json()
                    : { message: (await response.text()).slice(0, 200) };

                  if (!response.ok) {
                    throw new Error(
                      payload.message ||
                      payload.error ||
                      (response.status === 401 || response.status === 403
                        ? '로그인이 필요합니다.'
                        : '업로드에 실패했습니다.')
                    );
                  }

                  if (!payload.url) {
                    throw new Error(payload.message || '업로드된 파일 URL이 없습니다.');
                  }

                  const range = boardPostQuill.getSelection(true);
                  const index = range ? range.index : boardPostQuill.getLength();
                  boardPostQuill.insertEmbed(index, 'image', payload.url, 'user');
                  boardPostQuill.setSelection(index + 1, 0, 'silent');
                } catch (error) {
                  window.alert(error?.message || '이미지 업로드에 실패했습니다.');
                }
              }, { once: true });
              fileInput.click();
            }
          }
        }
      },
      placeholder: 'Write your post...'
