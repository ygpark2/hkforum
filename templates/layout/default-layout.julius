      updateFollowButton(button, isFollowing);
    });
});

document.addEventListener('DOMContentLoaded', () => {
  document
    .querySelectorAll('[data-action-type=\"post-watch\"][data-watching]')
    .forEach((button) => {
      const isWatching = button.getAttribute('data-watching') === 'true';
      updateWatchButton(button, isWatching);
    });
});
