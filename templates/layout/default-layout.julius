const THEME_STORAGE_KEY = 'hkforum-theme';
const HOME_CUSTOM_TABS_KEY = 'hkforum-home-custom-tabs';

const syncThemeSwitches = () => {
  const isDark = document.documentElement.dataset.theme === 'dark';
  document.querySelectorAll('[data-theme-switch]').forEach((switchEl) => {
    const thumb = switchEl.querySelector('[data-theme-switch-thumb]');
    if (!thumb) return;
    switchEl.style.backgroundColor = isDark ? '#0f172a' : '#ffffff';
    switchEl.style.borderColor = isDark ? '#0f172a' : '#cbd5e1';
    thumb.style.backgroundColor = isDark ? '#ffffff' : '#0f172a';
    thumb.style.transform = isDark ? 'translateX(24px)' : 'translateX(0)';
  });
};

const applyTheme = (theme) => {
  document.documentElement.dataset.theme = theme;
  syncThemeSwitches();
};

const openDialogByKey = (key) => {
  if (!key) return;
  const modal = document.querySelector(`[data-modal="${key}"]`);
  if (!modal || typeof modal.showModal !== 'function') return;
  if (!modal.open) modal.showModal();
};

const closeDialogByKey = (key) => {
  if (!key) return;
  const modal = document.querySelector(`[data-modal="${key}"]`);
  if (!modal || typeof modal.close !== 'function') return;
  if (modal.open) modal.close();
};

const prepareGlobalPostModal = () => {
  const form = document.querySelector('[data-global-post-form]');
  if (!form) return;
  form.reset();
  if (globalPostQuill) {
    globalPostQuill.setContents([]);
  }
  const boardSelect = form.querySelector('select[name="boardId"]');
  if (boardSelect && boardSelect.options.length > 0) {
    boardSelect.selectedIndex = 0;
  }
  updateLocationSummary('global-post-latitude', 'global-post-longitude', 'global-post-location-summary');
};

let globalPostQuill = null;

const initGlobalPostQuill = () => {
  const form = document.querySelector('[data-global-post-form]');
  const editorRoot = document.getElementById('global-post-description-editor');
  const descriptionInput = document.getElementById('global-post-content-input');
  const uploadUrl = form?.dataset.uploadUrl;
  
  if (!editorRoot || globalPostQuill) return;

  const csrfInput = document.getElementById('csrf-token');
  const csrfParam = csrfInput?.dataset.csrfParam;
  const csrfToken = csrfInput?.value;

  const instantiate = () => {
    if (!window.Quill) return false;

    globalPostQuill = new window.Quill('#global-post-description-editor', {
      theme: 'snow',
      modules: {
        toolbar: {
          container: '#global-post-description-toolbar',
          handlers: {
            image: async () => {
              if (!uploadUrl) return;

              const fileInput = document.createElement('input');
              fileInput.type = 'file';
              fileInput.accept = 'image/*';
              fileInput.addEventListener('change', async () => {
                const file = fileInput.files?.[0];
                if (!file) return;

                const body = new FormData();
                body.append('file', file);
                if (csrfParam && csrfToken) {
                  body.append(csrfParam, csrfToken);
                }

                try {
                  const response = await fetch(uploadUrl, {
                    method: 'POST',
                    body,
                    headers: {
                      Accept: 'application/json',
                      'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'same-origin'
                  });
                  if (response.redirected && response.url.includes('/auth/')) {
                    throw new Error('로그인이 필요합니다.');
                  }

                  const contentType = response.headers.get('content-type') || '';
                  const payload = contentType.includes('application/json')
                    ? await response.json()
                    : { message: (await response.text()).slice(0, 200) };

                  if (!response.ok) {
                    throw new Error(
                      payload.message ||
                      payload.error ||
                      (response.status === 401 || response.status === 403
                        ? '로그인이 필요합니다.'
                        : '업로드에 실패했습니다.')
                    );
                  }

                  if (!payload.url) {
                    throw new Error(payload.message || '업로드된 파일 URL이 없습니다.');
                  }

                  const range = globalPostQuill.getSelection(true);
                  const index = range ? range.index : globalPostQuill.getLength();
                  globalPostQuill.insertEmbed(index, 'image', payload.url, 'user');
                  globalPostQuill.setSelection(index + 1, 0, 'silent');
                } catch (error) {
                  window.alert(error?.message || '이미지 업로드에 실패했습니다.');
                }
              }, { once: true });
              fileInput.click();
            }
          }
        }
      },
      placeholder: 'Share your thoughts'
    });

    return true;
  };

  if (!instantiate()) {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js';
    script.onload = instantiate;
    document.body.appendChild(script);
  }

  form?.addEventListener('submit', () => {
    if (globalPostQuill && descriptionInput) {
      descriptionInput.value = globalPostQuill.root.innerHTML;
    }
  });
};

let boardPostQuill = null;

